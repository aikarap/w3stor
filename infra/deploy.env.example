# === Deployment ===
DEPLOY_HOST=user@your-server-ip
REMOTE_DIR=/opt/w3stor

# === Database ===
DATABASE_URL=postgresql://w3stor:CHANGE_ME@postgres:5432/w3stor
POSTGRES_DB=w3stor
POSTGRES_USER=w3stor
POSTGRES_PASSWORD=CHANGE_ME

# === Redis ===
REDIS_URL=redis://redis:6379

# === Neo4j ===
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME

# === Pinata IPFS ===
PINATA_API_KEY=
PINATA_API_SECRET=
PINATA_JWT=
PINATA_GATEWAY_URL=https://your-gateway.mypinata.cloud
PINATA_GATEWAY_TOKEN=

# === x402 Payments ===
X402_EVM_PRIVATE_KEY=
X402_EVM_PAY_TO=

# === Filecoin ===
FILECOIN_PRIVATE_KEY=
FILECOIN_RPC_URL=https://api.calibration.node.glif.io/rpc/v1

# === AI / LLM ===
AI_GATEWAY_API_KEY=
AI_DEFAULT_MODEL=openai/gpt-4o-mini

# === Embeddings ===
EMBEDDING_MODEL=text-embedding-3-small

# === SIWE Auth ===
SIWE_JWT_SECRET=CHANGE_ME
SIWE_DOMAIN=w3stor.xyz

# === Server ===
PORT=4000
CORS_ORIGIN=*
DOMAIN=api.w3stor.xyz

# === Worker ===
WORKER_CONCURRENCY=5
WORKER_RATE_LIMIT_MAX=5
WORKER_RATE_LIMIT_DURATION=1000

# === Autoscaler ===
AUTOSCALER_MAX_WORKERS=4
AUTOSCALER_POLL_INTERVAL=30
AUTOSCALER_SCALE_UP_THRESHOLD=10
AUTOSCALER_SCALE_DOWN_THRESHOLD=3
AUTOSCALER_COOLDOWN=60
