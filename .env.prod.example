# === Postgres (used by docker-compose.prod.yml) ===
POSTGRES_DB=w3stor
POSTGRES_USER=w3stor
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# === Pinata IPFS ===
PINATA_API_KEY=
PINATA_API_SECRET=
PINATA_JWT=
PINATA_GATEWAY_URL=https://your-gateway.mypinata.cloud
PINATA_GATEWAY_TOKEN=

# === x402 Payments ===
X402_EVM_PRIVATE_KEY=
X402_EVM_PAY_TO=

# === Filecoin ===
FILECOIN_PRIVATE_KEY=
FILECOIN_RPC_URL=https://api.node.glif.io/rpc/v1

# === AI / LLM ===
AI_GATEWAY_API_KEY=
AI_DEFAULT_MODEL=openai/gpt-4o-mini

# === Server ===
CORS_ORIGIN=https://w3stor.xyz
DOMAIN=api.w3stor.xyz

# === These are injected automatically by docker-compose ===
# DATABASE_URL=postgresql://...  (composed from POSTGRES_* vars)
# REDIS_URL=redis://...          (hardcoded in compose)
