# === Postgres (set in docker-compose.prod.yml too) ===
POSTGRES_DB=w3stor
POSTGRES_USER=w3stor
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# === App secrets ===
PINATA_JWT=
X402_EVM_PRIVATE_KEY=
X402_EVM_PAY_TO=
FILECOIN_PRIVATE_KEY=
FILECOIN_RPC_URL=https://api.node.glif.io/rpc/v1
AI_GATEWAY_API_KEY=
AI_DEFAULT_MODEL=openai/gpt-4o-mini

# === Server ===
CORS_ORIGIN=https://w3stor.xyz
DOMAIN=api.w3stor.xyz

# === These are set automatically by docker-compose ===
# DATABASE_URL=postgresql://...  (injected by compose)
# REDIS_URL=redis://...          (injected by compose)
