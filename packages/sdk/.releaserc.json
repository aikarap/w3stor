{
	"branches": ["main"],
	"tagFormat": "@w3stor/sdk@${version}",
	"plugins": [
		[
			"@semantic-release/commit-analyzer",
			{
				"preset": "conventionalcommits",
				"releaseRules": [
					{ "type": "feat", "release": "minor" },
					{ "type": "fix", "release": "patch" },
					{ "type": "perf", "release": "patch" },
					{ "type": "refactor", "release": "patch" }
				]
			}
		],
		[
			"@semantic-release/release-notes-generator",
			{ "preset": "conventionalcommits" }
		],
		[
			"@semantic-release/exec",
			{
				"prepareCmd": "node -e \"const fs=require('fs');const p=JSON.parse(fs.readFileSync('package.json','utf8'));p.version='${nextRelease.version}';fs.writeFileSync('package.json',JSON.stringify(p,null,2)+'\\n')\"",
				"publishCmd": "npm publish --access public"
			}
		],
		[
			"@semantic-release/github",
			{ "successComment": false, "failTitle": false }
		]
	]
}
