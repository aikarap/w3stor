{
	"name": "@w3stor/cli",
	"version": "0.1.0",
	"description": "CLI for W3Stor — decentralized storage on Filecoin with x402 micropayments",
	"private": false,
	"type": "module",
	"bin": {
		"w3stor": "./dist/index.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"dev:cli": "bun --watch src/index.ts",
		"build": "bun build src/index.ts --outdir dist --target node --format esm --packages external",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"prepublishOnly": "bun run build"
	},
	"dependencies": {
		"@filoz/synapse-core": "^0",
		"@x402/evm": "^2.8.0",
		"@x402/fetch": "^2.8.0",
		"conf": "^13",
		"incur": "*",
		"viem": "^2"
	},
	"devDependencies": {
		"@types/bun": "latest"
	},
	"keywords": [
		"filecoin",
		"ipfs",
		"web3",
		"storage",
		"cli",
		"x402",
		"mcp"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/aikarap/w3stor",
		"directory": "packages/cli"
	}
}
